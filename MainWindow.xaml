<Window x:Class="BluetoothAudioReceiver.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="蓝牙音频接收器" Height="590" Width="450"
        MinHeight="560" MinWidth="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="#F5F7FB"
        FontFamily="Microsoft YaHei UI, Segoe UI"
        TextOptions.TextFormattingMode="Display"
        Icon="tech_app.ico"
        Closing="Window_Closing"
        StateChanged="Window_StateChanged">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextBrush" Color="#1E2530"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#6B7280"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#2D6CDF"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#245CC1"/>
        <SolidColorBrush x:Key="AccentPressedBrush" Color="#1E4FA7"/>
        <SolidColorBrush x:Key="SecondaryBrush" Color="#344054"/>
        <SolidColorBrush x:Key="SecondaryHoverBrush" Color="#465469"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#E4E8F0"/>

        <DropShadowEffect x:Key="PanelShadow" BlurRadius="18" ShadowDepth="1" Opacity="0.08"/>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect" Value="{StaticResource PanelShadow}"/>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="MinWidth" Value="116"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#D8DEE8"/>
                                <Setter Property="Foreground" Value="#7B8494"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentPressedBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="{StaticResource SecondaryBrush}"/>
            <Setter Property="MinWidth" Value="108"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource SecondaryHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#2B3646"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DeviceItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemChrome"
                                Background="#F7F9FC"
                                BorderBrush="#EEF1F6"
                                BorderThickness="1"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#EEF5FF"/>
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="#BCD3FA"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#2D6CDF"/>
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="#2D6CDF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Margin" Value="0,7,0,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <tb:TaskbarIcon x:Key="TrayIcon"
                        ToolTipText="蓝牙音频接收器"
                        TrayLeftMouseDown="TrayIcon_LeftClick"
                        TrayMouseDoubleClick="TrayIcon_LeftClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="显示主窗口"     Click="TrayShow_Click"/>
                    <Separator/>
                    <MenuItem Header="重连上次设备"   Click="TrayReconnect_Click"/>
                    <MenuItem Header="修复声音"       Click="TrayRepairAudio_Click"/>
                    <Separator/>
                    <MenuItem Header="退出"           Click="TrayExit_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#172033" Padding="22,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Width="42" Height="42" CornerRadius="8" Background="#2D6CDF" VerticalAlignment="Center">
                    <TextBlock Text="BT" Foreground="White" FontSize="15" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="蓝牙音频接收器"
                               Foreground="White"
                               FontSize="21"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Windows A2DP Sink · 自动重连"
                               Foreground="#B9C6DA"
                               FontSize="12"
                               Margin="0,3,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="16,16,16,7" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Width="30" Height="30" CornerRadius="15" Background="#F1F5F9" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot" Width="12" Height="12" Fill="#BBBBBB"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" Margin="12,0,12,0" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusText"
                               Text="未连接"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="DeviceNameText"
                               Text="点击扫描查找设备"
                               FontSize="12"
                               Foreground="{StaticResource MutedTextBrush}"
                               Margin="0,3,0,0"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <Border Grid.Column="2" Background="#F4F6FA" CornerRadius="6" Padding="8,4" VerticalAlignment="Center">
                    <TextBlock x:Name="AutoReconnectBadge"
                               Text="自动重连 ON"
                               FontSize="11"
                               Foreground="#25824F"
                               FontWeight="SemiBold"/>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Margin="16,7" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Margin="16,14,16,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="可接收音频的设备"
                               FontSize="13.5"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Grid.Column="1"
                               Text="A2DP"
                               FontSize="10.5"
                               Foreground="#667085"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </Grid>

                <ListBox x:Name="DeviceList"
                         Grid.Row="1"
                         BorderThickness="0"
                         Background="Transparent"
                         ItemContainerStyle="{StaticResource DeviceItem}"
                         SelectionChanged="DeviceList_SelectionChanged"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         Margin="10,0,10,10">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Width="34" Height="34" CornerRadius="8" Background="#EAF1FF" VerticalAlignment="Center">
                                    <TextBlock Text="♪" FontSize="18" FontWeight="Bold" Foreground="#2D6CDF"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1" Margin="11,0,10,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding StatusLabel}"
                                               FontSize="11"
                                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"
                                               Opacity="0.72"
                                               Margin="0,2,0,0"/>
                                </StackPanel>

                                <Border Grid.Column="2"
                                        Background="#EAF8F0"
                                        CornerRadius="5"
                                        Padding="7,3"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding IsPaired, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="已配对" FontSize="10.5" Foreground="#25824F" FontWeight="SemiBold"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock x:Name="EmptyHint"
                           Grid.Row="1"
                           Text="点击「扫描设备」查找可接收音频的设备"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center"
                           Foreground="{StaticResource MutedTextBrush}"
                           FontSize="12.5"
                           Margin="28"
                           TextWrapping="Wrap"/>
            </Grid>
        </Border>

        <Grid Grid.Row="3" Margin="16,7,16,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="ScanBtn"
                    Grid.Column="0"
                    Content="🔍  扫描设备"
                    Style="{StaticResource PrimaryBtn}"
                    Click="ScanBtn_Click"
                    Margin="0,0,8,0"/>
            <Button x:Name="ActionBtn"
                    Grid.Column="1"
                    Content="🔗  连接"
                    Style="{StaticResource PrimaryBtn}"
                    Click="ActionBtn_Click"
                    IsEnabled="False"
                    Margin="0,0,8,0"/>
            <Button x:Name="ResetBtn"
                    Grid.Column="2"
                    Content="🔧  修复声音"
                    Style="{StaticResource SecondaryBtn}"
                    Click="ResetBtn_Click"
                    IsEnabled="False"/>
        </Grid>

        <Border Grid.Row="4" Style="{StaticResource CardBorder}" Margin="16,0,16,16" Padding="16,10,16,14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="自动化"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}"
                           Margin="0,0,0,4"/>

                <UniformGrid Grid.Row="1" Columns="2">
                    <CheckBox x:Name="AutoReconnectCB"
                              Content="断开后自动重连"
                              IsChecked="True"
                              Checked="Options_Changed"
                              Unchecked="Options_Changed"/>
                    <CheckBox x:Name="AutoStartCB"
                              Content="启动时连接上次设备"
                              IsChecked="True"
                              Checked="Options_Changed"
                              Unchecked="Options_Changed"/>
                    <CheckBox x:Name="AutoLaunchCB"
                              Content="开机自动启动"
                              IsChecked="False"
                              Checked="Options_Changed"
                              Unchecked="Options_Changed"/>
                    <CheckBox x:Name="MinimizeToCB"
                              Content="关闭时最小化到托盘"
                              IsChecked="True"
                              Checked="Options_Changed"
                              Unchecked="Options_Changed"/>
                </UniformGrid>
            </Grid>
        </Border>
    </Grid>
</Window>
